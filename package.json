{
  "name": "kubix.group",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Landing page for Kubix Inc., the Panama holding company that owns Kodex Labs in the United Kingdom and the Dominican Republic. Built with Svelte and Vite.",
  "homepage": "https://kubix.group",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kodexlabs-io/kubix.group.git"
  },
  "author": "Kubix Inc.",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "lint": "eslint ${1:-.}",
    "format": "prettier --write --html-whitespace-sensitivity ignore ${1:-.}",
    "format:check": "prettier --check --html-whitespace-sensitivity ignore ${1:-.}",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.9.2",
    "@types/qrcode": "^1.5.6",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^4.1.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "qrcode": "^1.5.4"
  }
}
